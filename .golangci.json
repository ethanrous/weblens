{
  "version": "2",
  "linters": {
    "default": "fast",
    "enable": ["errcheck", "revive", "wsl_v5"],
    "disable": [
      "cyclop",
      "depguard",
      "dogsled",
      "funlen",
      "gochecknoinits",
      "gocognit",
      "gocyclo",
      "godot",
      "godox",
      "gomoddirectives",
      "interfacebloat",
      "lll",
      "maintidx",
      "mnd",
      "nestif",
      "tagalign",
      "wsl",
      "gocritic",
      "gomodguard"
    ],
    "exclusions": {
      "rules": [
        {
          "path": "services/embed/",
          "linters": ["revive"],
          "text": "avoid package names that conflict with Go standard library"
        }
      ]
    }
  }
}
